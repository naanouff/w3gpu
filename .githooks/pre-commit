#!/usr/bin/env bash
# Pre-commit hook — run `cargo xtask setup-hooks` once to install.
set -euo pipefail

echo "==> [pre-commit] cargo check — native targets..."
cargo check --workspace --exclude w3gpu-wasm 2>&1
if [ $? -ne 0 ]; then
  echo "[pre-commit] FAILED: native check. Fix errors before committing."
  exit 1
fi

echo "==> [pre-commit] cargo check — wasm32 target..."
cargo check -p w3gpu-wasm --target wasm32-unknown-unknown 2>&1
if [ $? -ne 0 ]; then
  echo "[pre-commit] FAILED: wasm32 check. Fix errors before committing."
  exit 1
fi

echo "==> [pre-commit] All checks passed."
